  "name": "mantine-next-nextra-template",
  "packageManager": "yarn@4.16.0",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "build": "next build && yarn build:pagefind",
    "build:pagefind": "pagefind --site .next/server/app --output-path public/_pagefind",
    "dev": "next dev",
    "oxlint": "oxlint .",
    "jest": "jest",
    "jest:watch": "jest --watch",
    "lint": "npm run oxlint && npm run stylelint",
    "format:test": "oxfmt --check \"**/*.{ts,tsx,css}\"",
    "format:write": "oxfmt --write \"**/*.{ts,tsx,css}\"",
    "release:major": "yarn version major",
    "release:minor": "yarn version minor",
    "release:patch": "yarn version patch",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "stylelint": "stylelint '**/*.css' --cache",
    "test": "npx next typegen && npm run format:test && npm run lint && npm run typecheck && npm run jest",
    "typecheck": "tsc --noEmit"
  },
  "version": "6.0.1"
