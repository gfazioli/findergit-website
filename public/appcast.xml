            <title>Version 0.1.0</title>
            <pubDate>Wed, 15 Apr 2026 08:31:53 +0000</pubDate>
            <sparkle:version>1</sparkle:version>
            <sparkle:shortVersionString>0.1.0</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <h2>FinderGit 0.1.0 — first public release</h2>
                <ul>
                    <li>Git-aware file browser with sortable columns</li>
                    <li>Status badges per repository: clean / dirty / unpushed</li>
                    <li>Inline diff viewer for modified files</li>
                    <li>Stage / unstage / commit / push / pull / fetch from the UI</li>
                    <li>Native Markdown preview via Quick Look (Space)</li>
                    <li>Auto-updates via Sparkle</li>
                </ul>
            ]]></description>
